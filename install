# ── Wallpaper ─────────────────────────────────────────────
info "Downloading NiiX Arch wallpaper..."
mkdir -p "$HOME/Pictures"
curl -L --retry 5 -o "$HOME/Pictures/niix-background.png" \
    "https://niixa.org/niix-background.png" 2>/dev/null \
    && log "Wallpaper downloaded" \
    || warn "Could not download wallpaper — set manually later"

