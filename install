sudo touch /var/lib/niixarch-firstboot-done

echo ""
echo -e "  ${GREEN}✓${NC}  ${WHITE}${BOLD}First-boot setup complete!${NC}"
echo -e "  ${PINK}────────────────────────────────────────────────${NC}"
echo -e "  ${CYAN}·${NC}  Steam: dGPU is automatic on hybrid systems · optional extras: ${GREEN}gamemoderun mangohud %command%${NC}"
echo -e "  ${CYAN}·${NC}  Steam one-time: Settings → Compatibility → Steam Play for all titles → ${GREEN}Proton-CachyOS${NC}"
echo -e "  ${CYAN}·${NC}  FreeSync/G-Sync monitor? Settings → Displays → enable ${GREEN}Variable Refresh Rate${NC}"
echo -e "  ${CYAN}·${NC}  Phone-friendly Wi-Fi hotspot: ${GREEN}niix-hotspot start${NC}"
