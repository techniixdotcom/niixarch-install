# ── Wait for network ──────────────────────────────────────
info "Checking network connectivity..."

_nm_connected() {
    nmcli -t -f CONNECTIVITY general 2>/dev/null | grep -q "^full$"
}

if _nm_connected; then
    log "Network ready"
else
    info "Waiting for network connectivity (no timeout — will wait as long as needed)..."
    attempt=0
    until _nm_connected; do
        attempt=$(( attempt + 1 ))
        echo -ne "\r  ·  Waiting for network... (attempt $attempt)"
        sleep 3
    done
    echo ""
    log "Network ready"
fi

# ════════════════════════════════════════════════════════
