# ════════════════════════════════════════════════════════

echo
echo -e "${GREEN}  ███╗   ██╗██╗██╗██╗  ██╗ █████╗ ${PINK} ██████╗ ███████╗${NC}"
echo -e "${GREEN}  ████╗  ██║██║██║╚██╗██╔╝██╔══██╗${PINK}██╔═══██╗██╔════╝${NC}"
echo -e "${GREEN}  ██╔██╗ ██║██║██║ ╚███╔╝ ███████║${PINK}██║   ██║███████╗${NC}"
echo -e "${GREEN}  ██║╚██╗██║██║██║ ██╔██╗ ██╔══██║${PINK}██║   ██║╚════██║${NC}"
echo -e "${GREEN}  ██║ ╚████║██║██║██╔╝ ██╗██║  ██║${PINK}╚██████╔╝███████║${NC}"
echo -e "${GREEN}  ╚═╝  ╚═══╝╚═╝╚═╝╚═╝  ╚═╝╚═╝  ╚═╝${PINK} ╚═════╝ ╚══════╝${NC}"
echo
echo -e "  ${WHITE}${BOLD}First-Boot Setup${NC}"
