# â”€â”€ Hardware detection (runs from live ISO) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
detect_hardware() {
    hr "Hardware Detection"
    info "Detecting hardware..."

    # CPU
    CPU_MODEL=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
    if grep -qi "AuthenticAMD" /proc/cpuinfo; then
        CPU_VENDOR="amd"
    elif grep -qi "GenuineIntel" /proc/cpuinfo; then
        CPU_VENDOR="intel"
    else
        CPU_VENDOR="unknown"
    fi
    log "CPU: $CPU_MODEL ($CPU_VENDOR)"

    # GPU â€” detect via lspci descriptions
    GPU_DESCS=$(lspci 2>/dev/null | grep -iE "VGA|3D|Display" | sed 's/.*: //')
    local has_nvidia has_amd has_intel
    has_nvidia=$(echo "$GPU_DESCS" | grep -ciE "NVIDIA" || true)
    has_amd=$(echo "$GPU_DESCS" | grep -ciE "\bAMD\b|\bATI\b|\bRadeon\b|Advanced Micro" || true)
    has_intel=$(echo "$GPU_DESCS" | grep -ciE "Intel" || true)

    if [[ "$has_nvidia" -gt 0 ]]; then
        GPU_VENDOR="nvidia"
        GPU_MODEL=$(echo "$GPU_DESCS" | grep -iE "NVIDIA" | head -1)
    elif [[ "$has_amd" -gt 0 ]]; then
        GPU_VENDOR="amd"
        GPU_MODEL=$(echo "$GPU_DESCS" | grep -iE "\bAMD\b|\bATI\b|\bRadeon\b|Advanced Micro" | head -1)
        if echo "$GPU_MODEL" | grep -qiE "RX 9[0-9]{3}"; then GPU_GEN="rdna4"
        elif echo "$GPU_MODEL" | grep -qiE "RX 7[0-9]{3}"; then GPU_GEN="rdna3"
        elif echo "$GPU_MODEL" | grep -qiE "RX 6[0-9]{3}"; then GPU_GEN="rdna2"
        else GPU_GEN="older"; fi
    elif [[ "$has_intel" -gt 0 ]]; then
        GPU_VENDOR="intel"
        GPU_MODEL=$(echo "$GPU_DESCS" | grep -iE "Intel" | head -1)
    fi
    log "GPU: $GPU_MODEL ($GPU_VENDOR${GPU_GEN:+ $GPU_GEN})"

    [[ "$GPU_VENDOR" == "unknown" || -z "$GPU_VENDOR" ]] \
        && warn "Could not detect GPU â€” drivers will need manual install"

    # RAM
    local mem_kb
    mem_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    MEM_TOTAL_GB=$(( mem_kb / 1024 / 1024 ))
    log "RAM: ~${MEM_TOTAL_GB}GB"

    # Storage type
    lsblk -d -o name,rota 2>/dev/null | grep -q "^nvme" && HAS_NVME=true
    lsblk -d -o name,rota 2>/dev/null | grep -q " 0$" && HAS_SSD=true
    log "Storage: NVMe=$HAS_NVME SSD=$HAS_SSD"

    # â”€â”€ Hypervisor / VM detection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local virt_type
    virt_type=$(systemd-detect-virt 2>/dev/null || echo "none")
    if [[ "$virt_type" != "none" ]]; then
        IS_VM=true
        log "Hypervisor detected: $virt_type"
        warn "Running in a VM: gaming packages, hardware sensors,"
        warn "and CPU-specific kernel params will be skipped or adjusted."
    else
        IS_VM=false
        log "Bare metal confirmed"
    fi
}

# â”€â”€ Step 0: Pre-flight checks â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
check_prereqs() {
    hr "Pre-flight Checks"
    info "Running pre-flight checks..."

    [ "$EUID" -eq 0 ]        || err "Please run as root"
    [ -d /sys/firmware/efi ] || err "Not booted in UEFI mode â€” enable UEFI in BIOS"

    info "Checking internet connection..."
    ping -c 1 -W 3 archlinux.org &>/dev/null \
        || err "No internet. For WiFi: iwctl  then  station wlan0 connect 'YourSSID'"

    for cmd in cryptsetup parted mkfs.btrfs python3 efibootmgr lsblk blkid; do
        command -v "$cmd" &>/dev/null || err "$cmd not found on live ISO"
    done

    loadkeys "$KEYMAP"   # load default (us) until user selects layout in gather_input
    log "Keyboard: $KEYMAP (default â€” will be updated after layout selection)"
    log "All checks passed"
}

# â”€â”€ Step 1: Auto-detect EFI partition (internal drives only) â”€
detect_efi() {
    hr "EFI Partition Detection"
    info "Detecting EFI System Partition..."

    # Primary: match EFI System Partition GUID, skip USB drives
    while IFS= read -r dev; do
        [[ -b "$dev" ]] || continue
        parent=$(lsblk -no PKNAME "$dev" 2>/dev/null)
        if [[ -n "$parent" ]] && is_removable "/dev/$parent"; then
            continue
        fi
        EFI_PART="$dev"
        break
    done < <(blkid -t PART_ENTRY_TYPE="c12a7328-f81f-11d2-ba4b-00a0c93ec93b" \
                   -o device 2>/dev/null)

    # Fallback: find FAT32 partition with esp flag on internal drives
    if [[ -z "$EFI_PART" ]]; then
        while IFS= read -r drive; do
            [[ -b "$drive" ]] || continue
            is_removable "$drive" && continue
            partnum=$(parted -m "$drive" print 2>/dev/null \
                | awk -F: '$7 ~ /esp/ || $7 ~ /boot/ {print $1; exit}')
            if [[ -n "$partnum" ]]; then
                if [[ "$drive" == *nvme* || "$drive" == *mmcblk* ]]; then
                    EFI_PART="${drive}p${partnum}"
                else
                    EFI_PART="${drive}${partnum}"
                fi
                break
            fi
        done < <(lsblk -dn -o PATH 2>/dev/null)
    fi

    [[ -n "$EFI_PART" && -b "$EFI_PART" ]] \
        || err "Could not find EFI System Partition on any internal drive."

    EFI_DRIVE_NAME=$(lsblk -no PKNAME "$EFI_PART" 2>/dev/null)
    EFI_DRIVE="/dev/$EFI_DRIVE_NAME"
    EFI_PART_NUM=$(lsblk -no PARTN "$EFI_PART" 2>/dev/null \
        || echo "$EFI_PART" | grep -o '[0-9]*$')

    EFI_SIZE=$(lsblk -no SIZE "$EFI_PART" 2>/dev/null || echo "?")
    log "EFI partition : $EFI_PART  ($EFI_SIZE)"
    log "EFI drive     : $EFI_DRIVE  (partition $EFI_PART_NUM)"

    # Warn if EFI partition is small â€” kernels + initramfs need ~150 MiB
    EFI_SIZE_BYTES=$(lsblk -bno SIZE "$EFI_PART" 2>/dev/null | head -1 | tr -d '[:space:]')
    EFI_SIZE_BYTES=${EFI_SIZE_BYTES:-0}
    if [[ "$EFI_SIZE_BYTES" -lt 209715200 ]] 2>/dev/null; then   # < 200 MiB
        warn "EFI partition is only $EFI_SIZE â€” this may be too small"
        warn "for Linux kernels + initramfs. Consider resizing it first."
        ask "Continue anyway? (y/N):"
        read -rp "  > " efi_ok
        [[ "$efi_ok" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
    fi
}

# â”€â”€ Step 2: Find free space or offer partition deletion â”€â”€â”€â”€
detect_free_spaces() {
    hr "Free Space / Partition Selection"
    info "Scanning internal drives for free space (>10 GiB)..."
    echo

    FREE_SPACE_LIST=$(python3 <<'PYEOF'
import subprocess

# Get all disks â€” internal only (RM=0 and not USB transport)
try:
    raw = subprocess.check_output(
        ['lsblk', '-dn', '-o', 'PATH,TYPE,RM,TRAN'],
        stderr=subprocess.DEVNULL, text=True
    )
except Exception:
    raw = ""

drives = []
for line in raw.strip().split('\n'):
    cols = line.split()
    if len(cols) < 3:
        continue
    path, dtype, rm = cols[0], cols[1], cols[2]
    tran = cols[3] if len(cols) > 3 else ''
    if dtype != 'disk' or rm != '0':
        continue
    if tran.lower() == 'usb':
        continue
    drives.append(path)

entries = []
for drive in drives:
    try:
        model = subprocess.check_output(
            ['lsblk', '-dn', '-o', 'MODEL', drive],
            stderr=subprocess.DEVNULL, text=True
        ).strip() or "Unknown"

        # 5 second timeout â€” prevents hanging on odd drives
        out = subprocess.check_output(
            ['timeout', '5', 'parted', '-m', drive, 'unit', 'MiB', 'print', 'free'],
            stderr=subprocess.DEVNULL, text=True
        )

        for line in out.strip().split('\n'):
            parts = line.rstrip(';').split(':')
            if len(parts) >= 4 and 'free' in parts[-1].lower():
                try:
                    start = float(parts[1].replace('MiB', ''))
                    end   = float(parts[2].replace('MiB', ''))
                    size  = end - start
                    if size > 10240:  # > 10 GiB
                        entries.append(
                            f"{drive}|{start:.0f}|{end:.0f}|{size/1024:.1f}|{model}"
                        )
                except Exception:
                    pass
    except Exception:
        pass

for i, e in enumerate(entries):
    print(f"{i}:{e}")
PYEOF
)

    if [[ -n "$FREE_SPACE_LIST" ]]; then
        echo -e "  ${WHITE}${BOLD}Available free space regions:${NC}"
        echo
        while IFS= read -r line; do
            idx="${line%%:*}"
            rest="${line#*:}"
            IFS='|' read -r drive start end size_gib model <<< "$rest"
            printf "  ${CYAN}[%s]${NC}  %-16s  %6.1f GiB  (%s)\n" \
                "$idx" "$drive" "$size_gib" "$model"
        done <<< "$FREE_SPACE_LIST"

        echo
        ask "Which region should Arch use? Enter the number:"
        read -rp "  > " CHOICE

        CHOSEN=$(echo "$FREE_SPACE_LIST" | grep "^${CHOICE}:")
        [[ -n "$CHOSEN" ]] || err "Invalid choice: $CHOICE"

        rest="${CHOSEN#*:}"
        IFS='|' read -r TARGET_DRIVE FREE_START FREE_END FREE_GiB FREE_MODEL <<< "$rest"

        log "Selected: $TARGET_DRIVE  (~${FREE_GiB} GiB)  [$FREE_MODEL]"
        return
    fi

    # â”€â”€ No free space found â€” offer partition deletion â”€â”€â”€â”€â”€â”€
    warn "No free space (>10 GiB) found on any internal drive."
    info "You can delete an existing partition to make room."
    echo
    echo -e "  ${RED}${BOLD}  Protected partitions (will NOT be listed):${NC}"
    echo -e "    - EFI System Partition"
    echo -e "    - Windows / NTFS partitions"
    echo -e "    - Microsoft Reserved (MSR)"
    echo -e "    - Recovery partitions"
    echo

    # Build list of deletable partitions on internal drives
    PART_LIST=$(python3 - "$EFI_PART" "$LOGFILE" <<'PYEOF'
import subprocess, sys

efi_part = sys.argv[1]
logfile = sys.argv[2]

def log(msg):
    with open(logfile, 'a') as f:
        f.write(f"[PARTLIST] {msg}\n")

# Get internal, non-USB disks
try:
    raw = subprocess.check_output(
        ['lsblk', '-dn', '-o', 'PATH,TYPE,RM,TRAN'],
        stderr=subprocess.DEVNULL, text=True
    )
except Exception as e:
    log(f"ERROR getting drives: {e}")
    raw = ""

drives = []
for line in raw.strip().split('\n'):
    cols = line.split()
    if len(cols) < 3:
        continue
    path, dtype, rm = cols[0], cols[1], cols[2]
    tran = cols[3] if len(cols) > 3 else ''
    if dtype != 'disk' or rm != '0':
        log(f"Skip drive {path}: type={dtype} rm={rm}")
        continue
    if tran.lower() == 'usb':
        log(f"Skip drive {path}: USB transport")
        continue
    drives.append(path)
    log(f"Internal drive: {path} tran={tran}")

# Protected partition type GUIDs (lowercase)
protected_guids = {
    'c12a7328-f81f-11d2-ba4b-00a0c93ec93b',  # EFI System
    'e3c9e316-0b5c-4db8-817d-f92df00215ae',  # Microsoft Reserved (MSR)
    'de94bba4-06d1-4d40-a16a-bfd50179d6ac',  # Windows Recovery
}

entries = []
for drive in drives:
    try:
        # Use plain text output with explicit separator â€” more reliable than JSON
        out = subprocess.check_output(
            ['lsblk', '-ln', '-o', 'PATH,SIZE,FSTYPE,PARTTYPE', drive],
            stderr=subprocess.DEVNULL, text=True
        )
        log(f"lsblk output for {drive}:\n{out}")

        for line in out.strip().split('\n'):
            cols = line.split()
            if len(cols) < 2:
                continue

            path = cols[0]
            size = cols[1]

            # Remaining columns: FSTYPE might be empty, PARTTYPE might be empty
            # We need to figure out which columns are which
            # If there are 4 cols: PATH SIZE FSTYPE PARTTYPE
            # If there are 3 cols: PATH SIZE FSTYPE (no parttype) or PATH SIZE PARTTYPE (no fstype)
            # If there are 2 cols: PATH SIZE (no fstype, no parttype)
            fstype = ''
            partguid = ''
            if len(cols) == 4:
                fstype = cols[2]
                partguid = cols[3].lower()
            elif len(cols) == 3:
                # Could be fstype or parttype â€” GUIDs have dashes
                if '-' in cols[2] and len(cols[2]) > 30:
                    partguid = cols[2].lower()
                else:
                    fstype = cols[2]

            # Skip the drive itself
            if path == drive:
                continue

            # Skip /dev/mapper devices
            if '/mapper/' in path:
                log(f"Skip {path}: mapper device")
                continue

            # Skip EFI partition
            if path == efi_part:
                log(f"Skip {path}: EFI partition")
                continue

            # Skip protected GUIDs
            if partguid in protected_guids:
                log(f"Skip {path}: protected GUID {partguid}")
                continue

            # Skip NTFS, vfat
            if fstype.lower() in ('ntfs', 'vfat', 'fat32', 'fat16'):
                log(f"Skip {path}: protected fs {fstype}")
                continue

            # Skip tiny partitions (<1 GiB)
            try:
                s = size.upper()
                if 'T' in s:
                    gib = float(s.replace('T','')) * 1024
                elif 'G' in s:
                    gib = float(s.replace('G',''))
                elif 'M' in s:
                    gib = float(s.replace('M','')) / 1024
                else:
                    gib = 0
                if gib < 1:
                    log(f"Skip {path}: too small ({size})")
                    continue
            except Exception:
                log(f"Skip {path}: can't parse size '{size}'")
                continue

            label = fstype.lower() if fstype else 'unknown'
            entries.append(f"{path}|{size}|{label}|{drive}")
            log(f"ELIGIBLE: {path} {size} {label}")

    except Exception as e:
        log(f"ERROR processing {drive}: {e}")

for i, e in enumerate(entries):
    print(f"{i}:{e}")
PYEOF
)

    if [[ -z "$PART_LIST" ]]; then
        err "No deletable partitions found.\nShrink a Windows volume in Disk Management first, then re-run."
    fi

    echo -e "  ${WHITE}${BOLD}Deletable partitions:${NC}"
    echo
    while IFS= read -r line; do
        idx="${line%%:*}"
        rest="${line#*:}"
        IFS='|' read -r path size label drive <<< "$rest"
        printf "  ${CYAN}[%s]${NC}  %-16s  %8s  (%s)\n" \
            "$idx" "$path" "$size" "$label"
    done <<< "$PART_LIST"

    echo
    echo -e "  ${RED}${BOLD}WARNING: The selected partition will be PERMANENTLY DELETED.${NC}"
    ask "Which partition should be deleted for Arch? Enter the number:"
    read -rp "  > " DEL_CHOICE

    DEL_CHOSEN=$(echo "$PART_LIST" | grep "^${DEL_CHOICE}:")
    [[ -n "$DEL_CHOSEN" ]] || err "Invalid choice: $DEL_CHOICE"

    rest="${DEL_CHOSEN#*:}"
    IFS='|' read -r DEL_PART DEL_SIZE DEL_LABEL DEL_DRIVE <<< "$rest"

    echo
    echo -e "  ${RED}${BOLD}You are about to DELETE:  $DEL_PART  ($DEL_SIZE, $DEL_LABEL)${NC}"
    echo -e "  ${RED}${BOLD}This CANNOT be undone.${NC}"
    echo
    ask "Type  DELETE  (uppercase) to confirm:"
    read -rp "  > " DEL_CONFIRM
    [[ "$DEL_CONFIRM" == "DELETE" ]] || { echo "Aborted. Nothing was changed."; exit 0; }

    # Get partition number
    DEL_PART_NUM=$(lsblk -no PARTN "$DEL_PART" 2>/dev/null)
    if [[ -z "$DEL_PART_NUM" ]]; then
        DEL_PART_NUM=$(echo "$DEL_PART" | grep -o '[0-9]*$')
    fi

    [[ -n "$DEL_PART_NUM" ]] || err "Could not determine partition number for $DEL_PART"

    # Close any LUKS containers on this partition
    if blkid -o value -s TYPE "$DEL_PART" 2>/dev/null | grep -q "crypto_LUKS"; then
        # Find the mapper name if open
        MAPPER_NAME=$(lsblk -lno NAME,TYPE "$DEL_PART" 2>/dev/null \
            | awk '$2 == "crypt" {print $1}')
        if [[ -n "$MAPPER_NAME" ]]; then
            info "Closing LUKS container /dev/mapper/$MAPPER_NAME..."
            cryptsetup close "$MAPPER_NAME" 2>/dev/null || true
        fi
    fi

    # Unmount if mounted
    umount "$DEL_PART" 2>/dev/null || true

    info "Deleting partition $DEL_PART (partition $DEL_PART_NUM on $DEL_DRIVE)..."
    parted -s "$DEL_DRIVE" rm "$DEL_PART_NUM"
    partprobe "$DEL_DRIVE"
    sleep 2

    log "Partition deleted"

    # Re-scan the drive for free space and use the largest region
    info "Scanning $DEL_DRIVE for freed space..."
    FREE_REGION=$(parted -m "$DEL_DRIVE" unit MiB print free 2>/dev/null \
        | awk -F: '$NF ~ /free/ {
            start = $2; end = $3;
            gsub(/MiB/, "", start); gsub(/MiB/, "", end);
            size = end - start;
            if (size > max) { max = size; best_start = start; best_end = end }
        } END { if (max > 0) printf "%s|%s|%s", best_start, best_end, max/1024 }')

    [[ -n "$FREE_REGION" ]] \
        || err "Could not find free space on $DEL_DRIVE after deletion"

    IFS='|' read -r FREE_START FREE_END FREE_GiB <<< "$FREE_REGION"

    # Set variables for the rest of the script
    TARGET_DRIVE="$DEL_DRIVE"

    log "Using freed space: $TARGET_DRIVE  (~${FREE_GiB%.*} GiB)"
}

# â”€â”€ WiFi detection (live ISO) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Checks if the live ISO is connected via WiFi. If so, reads the SSID
# from iwd and asks for the password so it can be written into the
# installed system's NM profile â€” meaning it connects automatically
# on first boot with no manual setup needed.
detect_wifi() {
    # Find the first wireless interface that is connected
    local wlan_iface=""
    local ssid=""

    # iwd stores state under /var/lib/iwd â€” present on Arch live ISO
    if command -v iwctl &>/dev/null; then
        # Get the first connected station
        wlan_iface=$(iwctl station list 2>/dev/null             | awk '/connected/{print $1}' | head -1)
    fi

    # Fallback: scan /sys for any wlan interface that has an associated AP
    if [[ -z "$wlan_iface" ]]; then
        for iface in /sys/class/net/wl*; do
            [[ -d "$iface" ]] || continue
            local name
            name=$(basename "$iface")
            if iw dev "$name" link 2>/dev/null | grep -q "SSID:"; then
                wlan_iface="$name"
                break
            fi
        done
    fi

    [[ -n "$wlan_iface" ]] || return 0   # not on WiFi â€” nothing to do

    # Read current SSID
    ssid=$(iwctl station "$wlan_iface" show 2>/dev/null         | awk '/Connected network/{print $NF}')

    # Fallback SSID read via iw
    if [[ -z "$ssid" ]]; then
        ssid=$(iw dev "$wlan_iface" link 2>/dev/null             | awk '/SSID:/{print $2}')
    fi

    [[ -n "$ssid" ]] || return 0   # connected but can't read SSID

    WIFI_DETECTED=true
    WIFI_SSID="$ssid"

    hr "WiFi Detected"
    log "Connected via WiFi: ${WHITE}$ssid${NC}  (interface: $wlan_iface)"
    info "The installer can save this network so your system"
    info "connects automatically on first boot."
    echo
    echo -e "  ${GREEN}[1]${NC}  ${WHITE}Yes${NC}  â€” save WiFi credentials to installed system"
    echo -e "  ${GREEN}[2]${NC}  ${WHITE}No${NC}   â€” skip  (set up WiFi manually after install)"
    read -rp "  Choose [1/2]: " WIFI_SAVE_CHOICE

    if [[ "$WIFI_SAVE_CHOICE" != "1" ]]; then
        WIFI_DETECTED=false
        info "WiFi credentials will not be saved."
        return 0
    fi

    # Try to read the PSK from iwd's stored profile
    # iwd stores profiles as /var/lib/iwd/<SSID>.psk (plain ini)
    local iwd_profile="/var/lib/iwd/${ssid}.psk"
    local psk=""
    if [[ -f "$iwd_profile" ]]; then
        psk=$(grep -i "^Passphrase=" "$iwd_profile" 2>/dev/null | cut -d= -f2-)
    fi

    if [[ -n "$psk" ]]; then
        WIFI_PASS="$psk"
        log "WiFi password read from iwd profile â€” no re-entry needed"
    else
        # iwd may store the PSK hashed â€” ask the user
        echo
        ask "WiFi password for "$ssid":"
        read -rsp "  > " WIFI_PASS; echo
        [[ -n "$WIFI_PASS" ]] || { warn "Empty password â€” WiFi credentials will not be saved."; WIFI_DETECTED=false; return 0; }
        ask "Confirm WiFi password:"
        read -rsp "  > " WIFI_PASS2; echo
        if [[ "$WIFI_PASS" != "$WIFI_PASS2" ]]; then
            warn "Passwords did not match â€” WiFi credentials will not be saved."
            WIFI_DETECTED=false
            WIFI_PASS=""
            return 0
        fi
    fi

    log "WiFi credentials captured for: $WIFI_SSID"
}

# â”€â”€ Step 3: Gather user input â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
gather_input() {
    hr "Installation Config"
    echo -e "  ${WHITE}${BOLD}Configure your NiiX Arch install:${NC}"
    echo

    # â”€â”€ Keyboard layout â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    echo -e "  ${WHITE}${BOLD}Keyboard Layout${NC}"
    echo -e "  ${GREEN}[1]${NC}  ${WHITE}US${NC}              â€” English (US)"
    echo -e "  ${GREEN}[2]${NC}  ${WHITE}Swiss German${NC}    â€” de_CH  (Ã¼ Ã¶ Ã¤)"
    read -rp "  Choose [1/2]: " KB_CHOICE
    case "$KB_CHOICE" in
        2)
            KEYMAP="de_CH-latin1"
            KEYMAP_X11="ch"
            log "Keyboard: Swiss German (de_CH-latin1 / ch)"
            ;;
        *)
            KEYMAP="us"
            KEYMAP_X11="us"
            log "Keyboard: US"
            ;;
    esac

    # Apply to the live ISO immediately so passwords can be typed correctly
    loadkeys "$KEYMAP"

    # Detect WiFi and optionally capture credentials for the installed system
    detect_wifi

    ask "Hostname (e.g. archbox):"
    read -rp "  > " HOSTNAME
    [[ -n "$HOSTNAME" ]] || err "Hostname cannot be empty"

    ask "Username:"
    read -rp "  > " USERNAME
    [[ -n "$USERNAME" ]] || err "Username cannot be empty"

    echo
    ask "User & root password:"
    read -rsp "  > " USER_PASS; echo
    [[ -n "$USER_PASS" ]] || err "Password cannot be empty"
    ask "Confirm password:"
    read -rsp "  > " USER_PASS2; echo
    [[ "$USER_PASS" == "$USER_PASS2" ]] || err "Passwords do not match"

    echo
    warn "LUKS passphrase â€” typed every time you boot into Arch:"
    ask "LUKS passphrase:"
    read -rsp "  > " LUKS_PASS; echo
    [[ -n "$LUKS_PASS" ]] || err "LUKS passphrase cannot be empty"
    ask "Confirm LUKS passphrase:"
    read -rsp "  > " LUKS_PASS2; echo
    [[ "$LUKS_PASS" == "$LUKS_PASS2" ]] || err "LUKS passphrases do not match"

    echo
    ask "Timezone (press Enter for Europe/Zurich):"
    read -rp "  > " TIMEZONE
    TIMEZONE=${TIMEZONE:-Europe/Zurich}
    [ -f "/usr/share/zoneinfo/$TIMEZONE" ] \
        || err "Invalid timezone: $TIMEZONE"

    echo
    echo -e "  ${WHITE}${BOLD}CPU Vulnerability Mitigations${NC}"
    echo -e "  ${DIM}Disabling gives ~5-10% more FPS but reduces side-channel protection.${NC}"
    echo -e "  ${GREEN}[1]${NC}  ${WHITE}OFF${NC}  â€” Max performance  (mitigations=off)"
    echo -e "  ${GREEN}[2]${NC}  ${WHITE}ON${NC}   â€” Keep protections  (safer for banking/crypto)"
    read -rp "  Choose [1/2]: " MIT_CHOICE
    case "$MIT_CHOICE" in
        2) USE_MITIGATIONS=true;  log "Mitigations: ON" ;;
        *) USE_MITIGATIONS=false; log "Mitigations: OFF" ;;
    esac
}

# â”€â”€ Step 4: Confirm â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
confirm() {
    hr "Summary & Confirmation"
    echo -e "  ${WHITE}${BOLD}Review carefully before continuing:${NC}"
    echo
    echo -e "  ${PINK}â”€â”€ Hardware â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€${NC}"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "CPU:"  "$CPU_MODEL ($CPU_VENDOR)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "GPU:"  "$GPU_MODEL ($GPU_VENDOR)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "RAM:"  "~${MEM_TOTAL_GB}GB"
    echo
    echo -e "  ${PINK}â”€â”€ Install mode â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€${NC}"
    if [[ "$INSTALL_MODE" == "dualboot" ]]; then
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Mode:"            "Dual-boot  (Windows preserved)"
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "EFI (/boot):"     "$EFI_PART  (reused, NOT reformatted)"
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "New partition:"   "$TARGET_DRIVE  (free space)"
    else
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Mode:"            "Single-boot  (standalone Arch)"
        printf "  ${RED}âœ—${NC}  %-22s ${RED}%s${NC}\n"   "WIPE target:"     "$SINGLE_DRIVE  â€” ENTIRE DRIVE WIPED"
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "EFI partition:"   "512 MiB  (new, created on $SINGLE_DRIVE)"
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Root partition:"  "Remaining space on $SINGLE_DRIVE"
    fi
    echo
    echo -e "  ${PINK}â”€â”€ Configuration â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€${NC}"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Bootloader:"    "Limine (UEFI)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Keyboard:"      "$KEYMAP  (X11: $KEYMAP_X11)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Kernel:"        "linux-cachyos (BORE â€” installed first-boot)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Encryption:"    "LUKS2"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Filesystem:"    "Btrfs  Â·  @  @home  @snapshots  @var_log"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Swap:"          "ZRAM (zstd, auto-sized)"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Hostname:"      "$HOSTNAME"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Username:"      "$USERNAME"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Desktop:"       "GNOME"
    printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "Mitigations:"   "$([ "$USE_MITIGATIONS" = true ] && echo ON || echo OFF)"
    if [[ "$WIFI_DETECTED" == true ]]; then
        printf "  ${CYAN}Â·${NC}  %-22s ${WHITE}%s${NC}\n" "WiFi network:"  "$WIFI_SSID  (credentials saved)"
    fi
    echo
    if [[ "$INSTALL_MODE" == "dualboot" ]]; then
        warn "Only the selected free space will be touched â€” Windows is safe."
    else
        warn "ALL data on $SINGLE_DRIVE will be permanently destroyed."
        warn "This includes any OS, files, or partitions on that drive."
    fi
    echo
    echo -e "  ${RED}${BOLD}Type  YES  (uppercase) to begin â€” this cannot be undone:${NC}"
    read -rp "  > " CONFIRM_INPUT
    [[ "$CONFIRM_INPUT" == "YES" ]] || { echo "  Aborted. Nothing was changed."; exit 0; }
}

# â”€â”€ Step 5: Create partition in selected free space â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
create_partition() {
    hr "Partition Creation"
    info "Creating partition on $TARGET_DRIVE..."

    PARTS_BEFORE=$(lsblk -lno NAME "$TARGET_DRIVE" 2>/dev/null)

    PART_END=$(( ${FREE_END%.*} - 1 ))
    parted -s "$TARGET_DRIVE" mkpart primary "${FREE_START}MiB" "${PART_END}MiB"

    partprobe "$TARGET_DRIVE"
    sleep 2

    PARTS_AFTER=$(lsblk -lno NAME "$TARGET_DRIVE" 2>/dev/null)
    NEW_PART_NAME=$(diff <(echo "$PARTS_BEFORE") <(echo "$PARTS_AFTER") \
        | grep '^>' | awk '{print $2}' | head -1)

    [[ -n "$NEW_PART_NAME" ]] \
        || err "Could not identify new partition. Run: lsblk $TARGET_DRIVE"

    LUKS_PART="/dev/$NEW_PART_NAME"
    [[ -b "$LUKS_PART" ]] || err "New partition $LUKS_PART is not a block device"

    # Set Linux filesystem type GUID on GPT
    NEW_PART_NUM=$(lsblk -no PARTN "$LUKS_PART" 2>/dev/null \
        || echo "$LUKS_PART" | grep -o '[0-9]*$')
    parted -s "$TARGET_DRIVE" type "$NEW_PART_NUM" \
        "0FC63DAF-8483-4772-8E79-3D69D8477DE4" 2>/dev/null \
        || true   # older parted may not support 'type'; harmless

    log "New partition: $LUKS_PART"
}

# â”€â”€ Step 6: LUKS2 encryption â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
setup_luks() {
    hr "LUKS2 Encryption Setup"
    log "Formatting $LUKS_PART with LUKS2..."

    echo -n "$LUKS_PASS" | cryptsetup luksFormat \
        --batch-mode \
        --type luks2 \
        "$LUKS_PART" \
        --key-file=-

    LUKS_UUID=$(blkid -s UUID -o value "$LUKS_PART")
    [[ -n "$LUKS_UUID" ]] || err "Could not read UUID from $LUKS_PART"
    log "LUKS2 UUID: $LUKS_UUID"

    log "Opening container as /dev/mapper/$MAPPER..."
    echo -n "$LUKS_PASS" | cryptsetup open \
        "$LUKS_PART" "$MAPPER" \
        --key-file=-

    [[ -b "/dev/mapper/$MAPPER" ]] || err "Failed to open LUKS container"
    log "Container open at /dev/mapper/$MAPPER"
}

# â”€â”€ Step 7: Btrfs + subvolumes â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
setup_btrfs() {
    hr "Btrfs Filesystem"
    log "Formatting /dev/mapper/$MAPPER as Btrfs..."
    mkfs.btrfs -f /dev/mapper/$MAPPER

    log "Creating subvolumes..."
    mount /dev/mapper/$MAPPER /mnt
    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@snapshots
    btrfs subvolume create /mnt/@var_log
    umount /mnt

    log "Mounting subvolumes..."
    mount -o "${BTRFS_OPTS},subvol=@"          /dev/mapper/$MAPPER /mnt
    mkdir -p /mnt/{boot,home,.snapshots,var/log}
    mount "$EFI_PART" /mnt/boot
    mount -o "${BTRFS_OPTS},subvol=@home"      /dev/mapper/$MAPPER /mnt/home
    mount -o "${BTRFS_OPTS},subvol=@snapshots" /dev/mapper/$MAPPER /mnt/.snapshots
    mount -o "${BTRFS_OPTS},subvol=@var_log"   /dev/mapper/$MAPPER /mnt/var/log

    log "Btrfs mounted"
}

# â”€â”€ Step 7b: Remove ALL traces of previous Arch/Limine â”€â”€â”€â”€â”€â”€
clean_efi() {
    hr "EFI Partition Cleanup"
    info "Removing all traces of previous Arch/Limine installations..."
    info "(Windows and EFI/Microsoft files will NOT be touched)"

    # â”€â”€ 1. Clean files from EFI partition â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Kernels and initramfs (stock + cachyos)
    rm -f /mnt/boot/vmlinuz-linux*
    rm -f /mnt/boot/initramfs-linux*.img

    # Limine configs everywhere
    rm -rf /mnt/boot/limine
    rm -f  /mnt/boot/limine.cfg
    rm -f  /mnt/boot/limine.conf

    # Limine EFI binary
    rm -rf /mnt/boot/EFI/limine

    # GRUB (in case a previous manual install left it)
    rm -rf /mnt/boot/EFI/GRUB
    rm -rf /mnt/boot/grub

    # systemd-boot (in case archinstall left it)
    rm -rf /mnt/boot/EFI/systemd
    rm -rf /mnt/boot/loader

    # Any leftover Arch UKIs
    rm -rf /mnt/boot/EFI/Linux

    log "EFI partition cleaned"

    # â”€â”€ 2. Remove old Limine/Arch UEFI boot entries â”€â”€â”€â”€â”€â”€â”€â”€â”€
    info "Cleaning old UEFI NVRAM boot entries..."
    while IFS= read -r bootnum; do
        efibootmgr -b "$bootnum" -B 2>/dev/null \
            && log "Removed UEFI entry Boot${bootnum}" \
            || true
    done < <(efibootmgr 2>/dev/null \
        | grep -iE "limine|arch" \
        | grep -oP 'Boot\K[0-9A-Fa-f]{4}')

    log "UEFI NVRAM cleaned"
}

# â”€â”€ Step 8: Swiss mirrors & base install â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
install_base() {
    hr "Base System Install"
    info "Fetching fastest $MIRROR_COUNTRY mirrors..."
    pacman -Sy --noconfirm reflector 2>/dev/null \
        && reflector \
            --country "$MIRROR_COUNTRY" \
            --latest 10 \
            --protocol https \
            --sort rate \
            --save /etc/pacman.d/mirrorlist \
        && log "Mirrors updated" \
        || warn "reflector failed â€” using default mirrors"

    # Write vconsole.conf BEFORE pacstrap so mkinitcpio's keymap hook doesn't error
    mkdir -p /mnt/etc
    echo "KEYMAP=${KEYMAP}" > /mnt/etc/vconsole.conf

    log "Installing base system (this takes 10-20 minutes)..."
    pacstrap /mnt \
        base base-devel linux linux-firmware \
        networkmanager efibootmgr \
        sudo nano vim git wget curl \
        ntfs-3g dosfstools \
        btrfs-progs cryptsetup \
        limine \
        pipewire pipewire-alsa pipewire-pulse wireplumber

    log "Base system installed"
}

# â”€â”€ CachyOS repo + kernel â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# (CachyOS kernel installed during first-boot â€” needs live system for PGP keys)

# â”€â”€ GPU drivers (auto-detected) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
install_gpu_drivers() {
    hr "GPU Driver Install"
    info "Installing $GPU_VENDOR GPU drivers..."

    # Enable multilib for 32-bit libraries (needed by GPU drivers + Steam)
    if ! grep -q "^\[multilib\]" /mnt/etc/pacman.conf; then
        sed -i '/^#\[multilib\]/,/^#Include/ s/^#//' /mnt/etc/pacman.conf
    fi
    # Parallel downloads
    sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /mnt/etc/pacman.conf
    arch-chroot /mnt pacman -Sy --noconfirm

    case "$GPU_VENDOR" in
        amd)
            arch-chroot /mnt pacman -S --noconfirm --needed \
                mesa lib32-mesa \
                vulkan-radeon lib32-vulkan-radeon \
                vulkan-icd-loader lib32-vulkan-icd-loader \
                libva-mesa-driver lib32-libva-mesa-driver \
                xf86-video-amdgpu
            # AMD environment vars
            cat >> /mnt/etc/environment <<'AMDENV'
AMD_VULKAN_ICD=RADV
LIBVA_DRIVER_NAME=radeonsi
MOZ_DISABLE_RDD_SANDBOX=1
AMDENV
            log "AMD GPU drivers installed"
            ;;
        nvidia)
            local nvidia_pkg="nvidia-dkms"
            # Use open driver for Turing+ (RTX 20xx, GTX 16xx, RTX 30xx+)
            if echo "$GPU_MODEL" | grep -qiE "RTX [2-9]0|RTX [0-9]{4}|GTX 16"; then
                nvidia_pkg="nvidia-open-dkms"
            fi
            arch-chroot /mnt pacman -S --noconfirm --needed \
                "$nvidia_pkg" nvidia-utils lib32-nvidia-utils \
                nvidia-settings \
                vulkan-icd-loader lib32-vulkan-icd-loader \
                libva-nvidia-driver
            # NVIDIA modprobe config
            echo "options nvidia-drm modeset=1 fbdev=1" > /mnt/etc/modprobe.d/nvidia.conf
            # NVIDIA environment vars
            cat >> /mnt/etc/environment <<'NVENV'
LIBVA_DRIVER_NAME=nvidia
MOZ_DISABLE_RDD_SANDBOX=1
__GL_SHADER_DISK_CACHE=1
__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
GBM_BACKEND=nvidia-drm
__GLX_VENDOR_LIBRARY_NAME=nvidia
WLR_NO_HARDWARE_CURSORS=1
NVENV
            log "NVIDIA GPU drivers installed ($nvidia_pkg)"
            ;;
        intel)
            arch-chroot /mnt pacman -S --noconfirm --needed \
                mesa lib32-mesa \
                vulkan-intel lib32-vulkan-intel \
                vulkan-icd-loader lib32-vulkan-icd-loader \
                intel-media-driver libva-intel-driver lib32-libva-intel-driver
            cat >> /mnt/etc/environment <<'INTENV'
LIBVA_DRIVER_NAME=iHD
MOZ_DISABLE_RDD_SANDBOX=1
INTENV
            log "Intel GPU drivers installed"
            ;;
        *)
            if [[ "$IS_VM" == true ]]; then
                # Install appropriate guest drivers based on hypervisor
                local virt_type
                virt_type=$(systemd-detect-virt 2>/dev/null || echo "none")
                case "$virt_type" in
                    kvm|qemu)
                        arch-chroot /mnt pacman -S --noconfirm --needed \
                            mesa lib32-mesa \
                            vulkan-virtio lib32-vulkan-virtio \
                            vulkan-icd-loader lib32-vulkan-icd-loader \
                            spice-vdagent \
                            qemu-guest-agent
                        arch-chroot /mnt systemctl enable qemu-guest-agent 2>/dev/null || true
                        log "KVM/QEMU guest drivers installed (virtio-gpu + spice)"
                        ;;
                    vmware)
                        arch-chroot /mnt pacman -S --noconfirm --needed \
                            mesa lib32-mesa \
                            open-vm-tools
                        arch-chroot /mnt systemctl enable vmtoolsd 2>/dev/null || true
                        log "VMware guest drivers installed (open-vm-tools)"
                        ;;
                    oracle)
                        arch-chroot /mnt pacman -S --noconfirm --needed \
                            mesa lib32-mesa \
                            virtualbox-guest-utils
                        arch-chroot /mnt systemctl enable vboxservice 2>/dev/null || true
                        log "VirtualBox guest drivers installed"
                        ;;
                    *)
                        arch-chroot /mnt pacman -S --noconfirm --needed \
                            mesa lib32-mesa \
                            vulkan-icd-loader lib32-vulkan-icd-loader
                        log "Generic mesa drivers installed (unknown hypervisor: $virt_type)"
                        ;;
                esac
            else
                warn "Unknown GPU vendor â€” drivers will need manual install"
            fi
            ;;
    esac
}

# â”€â”€ All pacman packages (gaming, security, tools) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
install_packages() {
    hr "Package Install"
    info "Installing packages (gaming, security, tools)..."

    # Core packages â€” installed regardless of VM or bare metal
    arch-chroot /mnt pacman -S --noconfirm --needed \
        linux-headers \
        ufw \
        zram-generator \
        flatpak \
        dnsmasq \
        snapper snap-pac \
        gnome-terminal \
        fastfetch libva-utils dmidecode \
        gnome-shell-extension-appindicator \
        reflector

    if [[ "$IS_VM" == false ]]; then
        # Bare-metal only: gaming stack, hardware sensors, tablet support
        arch-chroot /mnt pacman -S --noconfirm --needed \
            gamemode lib32-gamemode mangohud lib32-mangohud \
            ananicy-cpp \
            steam \
            lib32-alsa-plugins lib32-libpulse lib32-openal \
            lib32-gst-plugins-base lib32-gst-plugins-good \
            irqbalance \
            power-profiles-daemon \
            iio-sensor-proxy \
            squeekboard
    else
        info "VM detected â€” skipping gaming stack, sensor daemons, and tablet packages"
    fi

    # CPU microcode
    case "$CPU_VENDOR" in
        amd)   arch-chroot /mnt pacman -S --noconfirm --needed amd-ucode ;;
        intel) arch-chroot /mnt pacman -S --noconfirm --needed intel-ucode ;;
    esac

    # CoreCtrl for AMD GPU control
    [[ "$GPU_VENDOR" == "amd" ]] && \
        arch-chroot /mnt pacman -S --noconfirm --needed corectrl || true

    log "All packages installed"
}

# â”€â”€ System configuration + tweaks â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
configure_system() {
    hr "System Configuration"
    log "Generating fstab..."
    genfstab -U /mnt >> /mnt/etc/fstab

    # Add /tmp as tmpfs to fstab
    if ! grep -q "^tmpfs.*/tmp" /mnt/etc/fstab; then
        echo "tmpfs /tmp tmpfs defaults,noatime,nosuid,nodev,size=4G 0 0" >> /mnt/etc/fstab
    fi

    # (mkinitcpio.conf written and rebuilt by rebuild_initramfs after all packages)

    # â”€â”€ Sysctl tuning (RAM-adaptive) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local swappiness=10
    [[ "$MEM_TOTAL_GB" -lt 24 ]] && swappiness=30
    [[ "$MEM_TOTAL_GB" -lt 12 ]] && swappiness=60

    cat > /mnt/etc/sysctl.d/99-niixarch.conf <<SYSEOF
vm.swappiness=$swappiness
vm.vfs_cache_pressure=50
vm.compaction_proactiveness=0
vm.watermark_boost_factor=0
kernel.nmi_watchdog=0
fs.inotify.max_user_watches=524288
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
SYSEOF
    log "Sysctl tuned (swappiness=$swappiness for ${MEM_TOTAL_GB}GB RAM)"

    # â”€â”€ Transparent hugepages â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    mkdir -p /mnt/etc/tmpfiles.d
    echo "w /sys/kernel/mm/transparent_hugepage/enabled - - - - madvise" \
        > /mnt/etc/tmpfiles.d/hugepages.conf

    # â”€â”€ NVMe I/O scheduler â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if [[ "$HAS_NVME" == true ]]; then
        mkdir -p /mnt/etc/udev/rules.d
        echo 'ACTION=="add|change", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="none"' \
            > /mnt/etc/udev/rules.d/60-nvme-scheduler.conf
    fi

    # â”€â”€ SSD I/O scheduler â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if [[ "$HAS_SSD" == true ]]; then
        mkdir -p /mnt/etc/udev/rules.d
        echo 'ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="none"' \
            > /mnt/etc/udev/rules.d/60-ssd-scheduler.conf
    fi

    # â”€â”€ ZRAM (auto-sized) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local zram_frac="ram / 2"
    [[ "$MEM_TOTAL_GB" -le 8 ]] && zram_frac="ram"
    cat > /mnt/etc/systemd/zram-generator.conf <<ZRAMEOF
[zram0]
zram-size = $zram_frac
compression-algorithm = zstd
ZRAMEOF

    # â”€â”€ Firewall (configure rules â€” ufw starts on boot via systemctl) â”€â”€
    arch-chroot /mnt bash <<'FWEOF'
ufw default deny incoming 2>/dev/null || true
ufw default allow outgoing 2>/dev/null || true
ufw allow 27036:27037/tcp 2>/dev/null || true
ufw allow 27031:27036/udp 2>/dev/null || true
# Don't run 'ufw --force enable' in chroot â€” no iptables modules
# ufw will start on boot via systemctl enable ufw
FWEOF

    # â”€â”€ MAC randomization (WiFi only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Ethernet is intentionally excluded â€” applying connection.stable-id
    # globally (with ${BOOT}) forces a new DHCP lease on every boot,
    # causing a ~10s stall before the network comes up.
    mkdir -p /mnt/etc/NetworkManager/conf.d
    cat > /mnt/etc/NetworkManager/conf.d/30-mac-randomize.conf <<'MACEOF'
[device-wifi-scan]
match-device=type:wifi
wifi.scan-rand-mac-address=yes

[connection-wifi-privacy]
match-device=type:wifi
wifi.cloned-mac-address=random
connection.stable-id=${CONNECTION}/${BOOT}
MACEOF

    # â”€â”€ WiFi auto-connect profile â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Write an NM keyfile for the WiFi network used during install so the
    # installed system connects automatically on first boot â€” no manual setup.
    if [[ "$WIFI_DETECTED" == true && -n "$WIFI_SSID" && -n "$WIFI_PASS" ]]; then
        local nm_conn_dir="/mnt/etc/NetworkManager/system-connections"
        mkdir -p "$nm_conn_dir"
        # Sanitise SSID for use as a filename (replace / and spaces)
        local safe_ssid
        safe_ssid=$(echo "$WIFI_SSID" | tr '/' '-' | tr ' ' '_')
        cat > "${nm_conn_dir}/${safe_ssid}.nmconnection" <<WIFIEOF
[connection]
id=${WIFI_SSID}
type=wifi
autoconnect=true

[wifi]
ssid=${WIFI_SSID}
mode=infrastructure

[wifi-security]
key-mgmt=wpa-psk
psk=${WIFI_PASS}

[ipv4]
method=auto

[ipv6]
method=auto
addr-gen-mode=stable-privacy
WIFIEOF
        # NM requires exactly 600 on keyfiles â€” it will refuse to load them otherwise
        chmod 600 "${nm_conn_dir}/${safe_ssid}.nmconnection"
        log "WiFi profile written: $WIFI_SSID  (auto-connect on first boot)"
    fi

    # â”€â”€ NetworkManager DNS backend â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Explicitly set NM to hand DNS off to systemd-resolved.
    # Without this, NM may try to use dnsmasq as its DNS plugin
    # (because dnsmasq is installed for hotspot use), which conflicts
    # with resolved and causes slow/broken DNS resolution at boot.
    # dnsmasq is still available and NM still invokes it for hotspots â€”
    # this only stops NM from using it as the global DNS backend.
    cat > /mnt/etc/NetworkManager/conf.d/10-dns-resolved.conf <<'NMEOF'
[main]
dns=systemd-resolved
systemd-resolved=false
NMEOF

    # â”€â”€ Ethernet link stability â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # The ethernet NIC drops carrier during auto-negotiation with the switch
    # (speed/duplex handshake), which causes NM to cancel a DHCP transaction
    # mid-flight and restart it â€” adding 20-30s before a lease is obtained.
    # ignore-carrier tells NM not to abort DHCP when the carrier briefly drops.
    # carrier-wait-timeout gives the link extra time to stabilise before NM
    # starts the DHCP transaction in the first place.
    cat > /mnt/etc/NetworkManager/conf.d/20-ethernet-stability.conf <<'ETHEOF'
[device-ethernet]
match-device=type:ethernet
ignore-carrier=yes
carrier-wait-timeout=2000
ETHEOF

    # â”€â”€ DNS-over-TLS (Cloudflare) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # DNSOverTLS=opportunistic â€” uses TLS when available but falls back
    # instantly rather than stalling boot waiting for a TLS handshake.
    # DNSOverTLS=yes (hard) adds several seconds of delay on every boot.
    mkdir -p /mnt/etc/systemd/resolved.conf.d
    cat > /mnt/etc/systemd/resolved.conf.d/dns-over-tls.conf <<'DNSEOF'
[Resolve]
DNS=1.1.1.1#cloudflare-dns.com 1.0.0.1#cloudflare-dns.com
FallbackDNS=9.9.9.9#dns.quad9.net 149.112.112.112#dns.quad9.net
DNSOverTLS=opportunistic
DNSSEC=allow-downgrade
DNSEOF

    # (LAVD scheduler set up during first-boot with CachyOS kernel)

    # â”€â”€ ntsync module â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    mkdir -p /mnt/etc/modules-load.d
    echo "ntsync" > /mnt/etc/modules-load.d/ntsync.conf

    # â”€â”€ Auto-update timer â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    cat > /mnt/etc/systemd/system/niixarch-update.service <<'UPDEOF'
[Unit]
Description=NiiX Arch System Update
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/pacman -Syu --noconfirm
UPDEOF

    cat > /mnt/etc/systemd/system/niixarch-update.timer <<'TMREOF'
[Unit]
Description=NiiX Arch Update Timer (every 12h)

[Timer]
OnBootSec=15min
OnUnitActiveSec=12h
Persistent=true
RandomizedDelaySec=30min

[Install]
WantedBy=timers.target
TMREOF

    # â”€â”€ CoreCtrl polkit (AMD only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if [[ "$GPU_VENDOR" == "amd" ]]; then
        mkdir -p /mnt/etc/polkit-1/rules.d
        cat > /mnt/etc/polkit-1/rules.d/90-corectrl.rules <<'POLEOF'
polkit.addRule(function(action, subject) {
    if ((action.id == "org.corectrl.helper.init" ||
         action.id == "org.corectrl.helperkiller.init") &&
        subject.local == true && subject.active == true &&
        subject.isInGroup("wheel")) { return polkit.Result.YES; }
});
POLEOF
    fi

    # â”€â”€ Configure + enable services in chroot â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    log "Configuring system in chroot..."
    arch-chroot /mnt bash <<CHROOT
set -e

ln -sf /usr/share/zoneinfo/${TIMEZONE} /etc/localtime
hwclock --systohc

echo "${LOCALE} UTF-8" >> /etc/locale.gen
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=${LOCALE}" > /etc/locale.conf

echo "KEYMAP=${KEYMAP}" > /etc/vconsole.conf

echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts <<EOF
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
EOF

sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# Enable services
systemctl enable NetworkManager
systemctl enable ananicy-cpp
systemctl enable ufw
systemctl enable systemd-resolved
systemctl enable niixarch-update.timer
# Hardware-specific services only on bare metal
if [[ "${IS_VM}" == "false" ]]; then
    systemctl enable irqbalance
    systemctl enable power-profiles-daemon
    systemctl enable iio-sensor-proxy
fi

# Disable NetworkManager-wait-online â€” it blocks boot until full network
# connectivity is confirmed, adding seconds of delay on every start.
# GNOME handles network state itself; this service is not needed.
systemctl disable NetworkManager-wait-online.service 2>/dev/null || true

# Symlink resolv.conf for DNS-over-TLS (|| true â€” may already exist)
ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf || true

# â”€â”€ Snapper â€” Btrfs snapshot management â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# snap-pac auto-creates pre/post snapshots on every pacman transaction.
# Timeline disabled â€” only pacman snapshots, last 10 kept.
mkdir -p /etc/snapper/configs
cat > /etc/snapper/configs/root <<'SNAPEOF'
SUBVOLUME="/"
FSTYPE="btrfs"
ALLOW_USERS=""
ALLOW_GROUPS=""
SYNC_ACL="no"
BACKGROUND_COMPARISON="yes"
NUMBER_CLEANUP="yes"
NUMBER_MIN_AGE="1800"
NUMBER_LIMIT="10"
NUMBER_LIMIT_IMPORTANT="5"
TIMELINE_CREATE="no"
TIMELINE_CLEANUP="no"
EMPTY_PRE_POST_CLEANUP="yes"
EMPTY_PRE_POST_MIN_AGE="1800"
SNAPEOF
chmod 750 /.snapshots
systemctl enable snapper-cleanup.timer
# Create the initial clean-install snapshot (pre-firstboot baseline)
snapper --no-dbus -c root create --description "NiiX Arch â€” clean install" 2>/dev/null || true
CHROOT

    log "LUKS UUID: $LUKS_UUID"

    # Set passwords and create user
    log "Setting passwords..."
    printf '%s\n' "root:${USER_PASS}" | arch-chroot /mnt chpasswd
    arch-chroot /mnt useradd -m -G wheel,audio,video,storage,optical \
        -s /bin/bash "${USERNAME}"
    printf '%s\n' "${USERNAME}:${USER_PASS}" | arch-chroot /mnt chpasswd

    log "System configured"
}

# â”€â”€ GNOME desktop + branding â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
install_desktop() {
    hr "GNOME + Branding"
    log "Installing GNOME (minimal â€” no gnome-extra bloat)..."
    # gnome-extra is a huge group full of GNOME games, maps, weather, etc.
    # We install only what's actually needed for a clean desktop.
    arch-chroot /mnt pacman -S --noconfirm --needed \
        gnome \
        gdm \
        gnome-terminal \
        gnome-tweaks \
        gnome-shell-extensions \
        gnome-disk-utility

    arch-chroot /mnt bash <<CHROOT
set -e
systemctl enable gdm

# GDM autologin â€” safe because LUKS2 already gates boot-time access
mkdir -p /etc/gdm
cat > /etc/gdm/custom.conf <<GDMEOF
[daemon]
AutomaticLoginEnable=True
AutomaticLogin=${USERNAME}
GDMEOF

mkdir -p /etc/X11/xorg.conf.d
cat > /etc/X11/xorg.conf.d/00-keyboard.conf <<EOF
Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "${KEYMAP_X11}"
EndSection
EOF

localectl set-x11-keymap "${KEYMAP_X11}"
CHROOT

    # â”€â”€ NiiX Arch branding â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    log "Applying NiiX Arch branding..."

    # os-release
    sed -i 's/^NAME=.*/NAME="NiiX Arch"/' /mnt/etc/os-release
    sed -i 's/^PRETTY_NAME=.*/PRETTY_NAME="NiiX Arch"/' /mnt/etc/os-release

    # /etc/issue
    echo "NiiX Arch \r (\l)" > /mnt/etc/issue

    # MOTD â€” kept plain text to avoid GDM/PAM rendering Unicode box art as
    # garbage characters on the graphical login screen (pam_motd displays this).
    # The NiiX Arch ASCII logo is shown via fastfetch in the terminal instead.
    cat > /mnt/etc/motd <<'MOTDEOF'

  Welcome to NiiX Arch
  Run 'fastfetch' for system info.

MOTDEOF

    # Branding persistence hook
    mkdir -p /mnt/etc/pacman.d/hooks
    cat > /mnt/etc/pacman.d/hooks/niixarch-branding.hook <<'HOOKEOF'
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = filesystem

[Action]
Description = Re-applying NiiX Arch branding...
When = PostTransaction
Exec = /bin/bash -c "sed -i 's/^NAME=.*/NAME=\"NiiX Arch\"/' /etc/os-release; sed -i 's/^PRETTY_NAME=.*/PRETTY_NAME=\"NiiX Arch\"/' /etc/os-release"
HOOKEOF

    # Shell performance vars (for all users)
    cat > /mnt/etc/profile.d/niixarch-gaming.sh <<'SHEOF'
export DXVK_ASYNC=1
export mesa_glthread=true
export WINEFSYNC=1
export WINEESYNC=1
export WINE_FULLSCREEN_FSR=1
export MESA_SHADER_CACHE_MAX_SIZE=10G
export PROTON_ENABLE_NTSYNC=1
SHEOF
    # GPU-specific vars
    if [[ "$GPU_VENDOR" == "nvidia" ]]; then
        cat >> /mnt/etc/profile.d/niixarch-gaming.sh <<'NVEOF'
export __GL_SHADER_DISK_CACHE=1
export __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
export __GL_THREADED_OPTIMIZATIONS=1
export PROTON_ENABLE_NVAPI=1
export PROTON_HIDE_NVIDIA_GPU=0
NVEOF
    elif [[ "$GPU_VENDOR" == "amd" ]]; then
        echo 'export RADV_PERFTEST=gpl' >> /mnt/etc/profile.d/niixarch-gaming.sh
    fi

    log "GNOME + branding installed"
}

# â”€â”€ Final initramfs build (MUST run after ALL packages) â”€â”€â”€â”€â”€â”€
rebuild_initramfs() {
    hr "Initramfs Rebuild"
    log "Writing final mkinitcpio.conf..."

    # mkinitcpio hooks â€” busybox encrypt for stock kernel, systemd sd-encrypt for CachyOS
    if [[ "$GPU_VENDOR" == "nvidia" ]]; then
        cat > /mnt/etc/mkinitcpio.conf <<'MKINIT'
MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm)
BINARIES=()
FILES=()
HOOKS=(base udev autodetect microcode modconf kms keyboard keymap consolefont block encrypt btrfs filesystems fsck)
MKINIT
    else
        cat > /mnt/etc/mkinitcpio.conf <<'MKINIT'
MODULES=()
BINARIES=()
FILES=()
HOOKS=(base udev autodetect microcode modconf kms keyboard keymap consolefont block encrypt btrfs filesystems fsck)
MKINIT
    fi

    log "mkinitcpio.conf:"
    cat /mnt/etc/mkinitcpio.conf

    log "Rebuilding initramfs (final â€” after all packages)..."
    arch-chroot /mnt mkinitcpio -P

    # Verify
    if lsinitcpio /mnt/boot/initramfs-linux.img 2>/dev/null | grep -q "cryptsetup"; then
        log "initramfs contains cryptsetup â€” LUKS prompt will work"
    else
        warn "cryptsetup NOT found in initramfs â€” check log"
        {
            echo "--- lsinitcpio initramfs-linux.img ---"
            lsinitcpio /mnt/boot/initramfs-linux.img 2>&1 || true
        } >> "$LOGFILE" 2>&1
    fi
}

# â”€â”€ Limine bootloader â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
install_limine() {
    hr "Limine Bootloader"
    log "Installing Limine bootloader..."

    # â”€â”€ 1. Copy EFI binary â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    mkdir -p /mnt/boot/EFI/limine /mnt/boot/EFI/BOOT
    cp /mnt/usr/share/limine/BOOTX64.EFI /mnt/boot/EFI/limine/BOOTX64.EFI
    # Also install as the UEFI fallback path â€” many BIOSes boot this
    # automatically when no NVRAM entry is found or has been cleared
    cp /mnt/usr/share/limine/BOOTX64.EFI /mnt/boot/EFI/BOOT/BOOTX64.EFI
    log "BOOTX64.EFI copied (\EFI\limine\ + fallback \EFI\BOOT\)"

    # â”€â”€ 2. Build kernel cmdline â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local CMDLINE="cryptdevice=UUID=${LUKS_UUID}:${MAPPER} root=/dev/mapper/${MAPPER} rootflags=subvol=@ rootfstype=btrfs rw"

    if [[ "$IS_VM" == false ]]; then
        # Bare-metal: CPU power management + hardware-specific params
        case "$CPU_VENDOR" in
            amd)   CMDLINE+=" amd_pstate=active split_lock_detect=off" ;;
            intel) CMDLINE+=" intel_pstate=active split_lock_detect=off" ;;
        esac
        [[ "$USE_MITIGATIONS" == false ]] && CMDLINE+=" mitigations=off"
        CMDLINE+=" usbhid.mousepoll=1"
        [[ "$GPU_VENDOR" == "amd" ]] && CMDLINE+=" amdgpu.ppfeaturemask=0xffffffff"
        [[ "$GPU_VENDOR" == "nvidia" ]] && CMDLINE+=" nvidia-drm.modeset=1"
    else
        # VM: skip pstate (no real CPU freq control), keep mitigations ON
        # (shared host â€” disabling mitigations in a VM is a security risk)
        CMDLINE+=" console=tty0 console=ttyS0"   # serial console for debugging
        warn "VM: mitigations kept ON, pstate params skipped"
    fi

    # â”€â”€ 3. Write Limine config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Limine 8+ uses volume-relative paths â€” no boot() macro.
    # /boot IS the EFI partition, so vmlinuz-linux is at the EFI root.
    mkdir -p /mnt/boot/limine /mnt/boot/EFI/limine

    if [[ "$INSTALL_MODE" == "dualboot" ]]; then
        cat > /mnt/boot/EFI/limine/limine.cfg <<EOF
timeout: 5
interface_branding: NiiX Arch
interface_branding_colour: 6
interface_help_hidden: yes
default_entry: 1

/Windows Boot Manager
    protocol: efi
    path: boot():/EFI/Microsoft/Boot/bootmgfw.efi

/NiiX Arch
    protocol: linux
    path: boot():/vmlinuz-linux
    cmdline: $CMDLINE
    module_path: boot():/initramfs-linux.img
EOF
    else
        cat > /mnt/boot/EFI/limine/limine.cfg <<EOF
timeout: 5
interface_branding: NiiX Arch
interface_branding_colour: 6
interface_help_hidden: yes
default_entry: 1

/NiiX Arch
    protocol: linux
    path: boot():/vmlinuz-linux
    cmdline: $CMDLINE
    module_path: boot():/initramfs-linux.img
EOF
    fi

    # Mirror config to every location Limine searches
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/EFI/limine/limine.conf
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/EFI/BOOT/limine.cfg
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/EFI/BOOT/limine.conf
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/limine/limine.cfg
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/limine/limine.conf
    cp /mnt/boot/EFI/limine/limine.cfg /mnt/boot/limine.cfg
    log "limine.cfg written to all search locations"

    # â”€â”€ 4. Purge all stale NiiX Arch / Limine NVRAM entries â”€â”€
    # Previous installs leave entries pointing to GPT GUIDs that no longer
    # exist. These shadow the new entry and break the boot order silently.
    info "Removing stale NiiX Arch / Limine NVRAM entries..."
    while IFS= read -r bootnum; do
        efibootmgr -b "$bootnum" -B 2>/dev/null             && log "  Removed stale NVRAM entry Boot${bootnum}"             || true
    done < <(efibootmgr 2>/dev/null         | grep -iE "NiiX Arch|Limine"         | grep -oP 'Boot\K[0-9A-Fa-f]{4}')
    log "Stale NVRAM entries cleared"

    # â”€â”€ 5. Register a single clean NVRAM entry â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local part_num
    part_num=$(echo "$EFI_PART_NUM" | tr -d '[:space:]')
    efibootmgr \
        --create \
        --disk  "$EFI_DRIVE" \
        --part  "$part_num" \
        --label "NiiX Arch (Limine)" \
        --loader '\EFI\limine\BOOTX64.EFI' \
        --unicode \
        && log "Limine registered in UEFI NVRAM" \
        || warn "efibootmgr failed â€” BIOS will use fallback \EFI\BOOT\BOOTX64.EFI"

    log "Limine registered in UEFI NVRAM"

    # Pacman hooks
    mkdir -p /mnt/etc/pacman.d/hooks
    cat > /mnt/etc/pacman.d/hooks/limine.hook <<'HOOKEOF'
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = limine

[Action]
Description = Updating Limine EFI binary...
When = PostTransaction
Exec = /bin/sh -c 'cp /usr/share/limine/BOOTX64.EFI /boot/EFI/limine/'
HOOKEOF

    cat > /mnt/etc/pacman.d/hooks/niixarch-limine.hook <<'HOOKEOF'
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = linux
Target = linux-cachyos
Target = limine

[Action]
Description = Re-applying NiiX Arch Limine branding...
When = PostTransaction
Exec = /bin/bash -c "for f in /boot/limine.conf /boot/limine/limine.conf; do [ -f \"$f\" ] && sed -i 's|^/Arch Linux.*|/NiiX Arch|' \"$f\"; done"
HOOKEOF

    log "Pacman hooks created"
}

# â”€â”€ First-boot script (AUR, GNOME settings, flatpaks) â”€â”€â”€â”€â”€â”€â”€â”€
setup_firstboot() {
    hr "First-Boot Setup"
    log "Setting up first-boot script..."

    # Temporary passwordless sudo for first-boot only.
    # Scoped to the specific user; removed by the firstboot script itself on completion.
    cat > /mnt/etc/sudoers.d/niixarch-firstboot <<SUDOEOF
# Temporary â€” grants ${USERNAME} passwordless sudo during first-boot setup.
# This file is automatically deleted when first-boot completes.
${USERNAME} ALL=(ALL) NOPASSWD: ALL
SUDOEOF
    chmod 440 /mnt/etc/sudoers.d/niixarch-firstboot
    log "Temporary passwordless sudo configured for first-boot"

    # Save hardware config for first-boot script
    cat > /mnt/etc/niixarch.conf <<CONFEOF
GPU_VENDOR=$GPU_VENDOR
CPU_VENDOR=$CPU_VENDOR
GPU_MODEL="$GPU_MODEL"
IS_DUALBOOT=$([[ "$INSTALL_MODE" == "dualboot" ]] && echo true || echo false)
CONFEOF

    # Write the first-boot script
    cat > /mnt/usr/local/bin/niixarch-firstboot.sh <<'FBEOF'
# !/bin/bash
# NiiX Arch First-Boot â€” CachyOS kernel, AUR packages, GNOME settings
# Run via autostart, or manually: bash /usr/local/bin/niixarch-firstboot.sh
set +e

source /etc/niixarch.conf 2>/dev/null || true

GREEN='\033[38;5;118m'
PINK='\033[38;5;205m'
RED='\033[0;31m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; WHITE='\033[1;37m'; BOLD='\033[1m'; NC='\033[0m'
log()  { echo -e "  ${GREEN}âœ“${NC}  $*"; }
warn() { echo -e "  ${YELLOW}âš ${NC}  $*"; }
info() { echo -e "  ${CYAN}Â·${NC}  $*"; }

LOG="$HOME/niixarch-firstboot-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG") 2>&1

# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# PHASE 1 â€” Offline setup (no internet required)
# Runs immediately so the desktop looks right straight away.
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# â”€â”€ GNOME settings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
info "Applying GNOME settings..."
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface enable-animations false 2>/dev/null || true
gsettings set org.gnome.desktop.sound event-sounds false 2>/dev/null || true
gsettings set org.gnome.desktop.session idle-delay 0 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.power power-button-action 'nothing' 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type 'nothing' 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-battery-type 'nothing' 2>/dev/null || true
gsettings set org.gnome.mutter dynamic-workspaces false 2>/dev/null || true
gsettings set org.gnome.desktop.wm.preferences num-workspaces 1 2>/dev/null || true
gsettings set org.gnome.desktop.notifications show-in-lock-screen false 2>/dev/null || true

# â”€â”€ Tablet mode / auto-rotate / on-screen keyboard â”€â”€â”€â”€â”€â”€â”€
# iio-sensor-proxy feeds the accelerometer data to GNOME.
# When the hinge sensor reports tablet mode, GNOME Shell:
#   - auto-rotates the display to match physical orientation
#   - shows the OSK automatically when a text field is focused
#   - hides the top-bar overview button and disables the touchpad
# These settings activate that behaviour without any user action.
gsettings set org.gnome.settings-daemon.peripherals.touchscreen orientation-lock false 2>/dev/null || true
gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled true 2>/dev/null || true

# Ctrl+Alt+T terminal shortcut
gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings "['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/']" 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/ name "Terminal" 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/ command "gnome-terminal" 2>/dev/null || true
gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/ binding "<Control><Alt>t" 2>/dev/null || true

# Enable AppIndicator (tray icons) + dash pinned apps
gnome-extensions enable appindicatorsupport@rgcjonas.gmail.com 2>/dev/null || true
gsettings set org.gnome.shell favorite-apps "['org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'steam.desktop', 'com.heroicgameslauncher.hgl.desktop']" 2>/dev/null || true
log "GNOME settings applied"

# â”€â”€ Performance profile â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo powerprofilesctl set performance 2>/dev/null || true

# â”€â”€ Gamemode config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
mkdir -p "$HOME/.config"
cat > "$HOME/.config/gamemode.ini" <<'GMEOF'
[general]
renice = 10
ioprio = 0
inhibit_screensaver = 1

[gpu]
apply_gpu_optimisations = accept-responsibility
amd_performance_level = high

[cpu]
pin_cores = yes

[custom]
start = notify-send "GameMode" "Gaming optimizations ON"
end = notify-send "GameMode" "Gaming optimizations OFF"
GMEOF

# â”€â”€ Bluetooth A2DP fix â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
mkdir -p "$HOME/.config/wireplumber/wireplumber.conf.d"
cat > "$HOME/.config/wireplumber/wireplumber.conf.d/51-bluetooth-fix.conf" <<'BTEOF'
monitor.bluez.properties = {
  bluez5.roles = [ a2dp_sink a2dp_source ]
  bluez5.codecs = [ sbc sbc_xq aac ldac ]
  bluez5.auto-connect = [ a2dp_sink ]
}
BTEOF

# â”€â”€ fastfetch on terminal open â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
echo 'fastfetch' >> "$HOME/.bashrc"

# â”€â”€ fastfetch config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
mkdir -p "$HOME/.config/fastfetch"
cat > "$HOME/.config/fastfetch/config.jsonc" <<'FFEOF'
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "builtin",
    "source": "arch",
    "color": { "1": "38;5;118", "2": "38;5;205" }
  },
  "display": { "separator": " â†’ ", "color": { "keys": "38;5;118", "title": "38;5;205" } },
  "modules": [
    { "type": "title", "format": "{user-name}@niixarch" }, "separator",
    { "type": "os", "key": "OS", "format": "NiiX Arch" },
    { "type": "kernel", "key": "Kernel" }, { "type": "uptime", "key": "Uptime" },
    { "type": "packages", "key": "Packages" }, { "type": "shell", "key": "Shell" },
    { "type": "de", "key": "DE" }, { "type": "terminal", "key": "Terminal" }, "separator",
    { "type": "cpu", "key": "CPU" }, { "type": "gpu", "key": "GPU" },
    { "type": "memory", "key": "Memory" }, { "type": "disk", "key": "Disk", "folders": "/" },
