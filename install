# â”€â”€ User input â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
HOSTNAME=""; USERNAME=""; USER_PASS=""; LUKS_PASS=""; TIMEZONE=""
WIFI_SSID=""; WIFI_PASS=""; WIFI_DETECTED=false
FREE_START=""; FREE_END=""
USE_MITIGATIONS=false

# â”€â”€ Hardware (detected at runtime) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
CPU_VENDOR=""; CPU_MODEL=""; GPU_VENDOR=""; GPU_MODEL=""; GPU_GEN=""
MEM_TOTAL_GB=0; HAS_NVME=false; HAS_SSD=false
IS_VM=false        # true when running inside a hypervisor

# â”€â”€ Output helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
log()  { echo -e "  ${GREEN}âœ“${NC}  $*"; }
warn() { echo -e "  ${YELLOW}âš ${NC}  $*"; }
err()  {
    echo -e "\n  ${RED}âœ—${NC}  ${RED}ERROR:${NC} $*"
    dump_state "ERROR: $*" 2>/dev/null || true
    echo -e "  ${CYAN}Â·${NC}  Log saved to: ${LOGFILE}"
    exit 1
}
info() { echo -e "  ${CYAN}Â·${NC}  $*"; }
ask()  { echo -e "\n  ${PINK}â–¸${NC}  ${WHITE}$*${NC}"; }

# Styled section header â€” called as: hr "Section Title"
# Also works as hr (no title) for a plain divider
hr() {
    echo
    if [[ -n "${1:-}" ]]; then
        echo -e "  ${PINK}â—ˆ${NC}  ${WHITE}${BOLD}${1}${NC}"
    fi
    echo -e "  ${PINK}â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€${NC}"
    echo
}

# Debug helper â€” writes ONLY to log file, not to screen
dbg() {
    echo "[DBG $(date +%H:%M:%S)] $*" >> "$LOGFILE"
}

# Dump system state to log for troubleshooting
dump_state() {
    local label="$1"
    {
        echo ""
        echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
        echo "  DEBUG DUMP: $label"
        echo "  $(date)"
        echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
        echo ""
        echo "--- lsblk -f ---"
        lsblk -f 2>&1 || true
        echo ""
        echo "--- blkid ---"
        blkid 2>&1 || true
        echo ""
        echo "--- efibootmgr ---"
        efibootmgr -v 2>&1 || true
        echo ""
        echo "--- df -h (mounted) ---"
        df -h 2>&1 || true
        echo ""
        echo "--- mount ---"
        mount 2>&1 || true
        echo ""
        echo "--- Script variables ---"
        echo "EFI_PART=$EFI_PART"
        echo "EFI_DRIVE=$EFI_DRIVE"
        echo "EFI_PART_NUM=$EFI_PART_NUM"
        echo "TARGET_DRIVE=$TARGET_DRIVE"
        echo "LUKS_PART=$LUKS_PART"
        echo "LUKS_UUID=$LUKS_UUID"
        echo "FREE_START=$FREE_START"
        echo "FREE_END=$FREE_END"
        echo "MAPPER=$MAPPER"
        echo ""
        echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
        echo ""
    } >> "$LOGFILE" 2>&1
}

# Returns 0 if a drive is removable (USB) or virtual (loop/ram/dm), 1 if internal physical
is_removable() {
    local dev
    dev=$(basename "$1")
    # Exclude loop devices, RAM disks, and device-mapper â€” these are never install targets
    [[ "$dev" == loop*  ]] && return 0
    [[ "$dev" == ram*   ]] && return 0
    [[ "$dev" == dm-*   ]] && return 0
    local rm_flag
    rm_flag=$(cat "/sys/block/${dev}/removable" 2>/dev/null || echo "0")
    [[ "$rm_flag" == "1" ]] && return 0
    # Also check transport â€” USB drives may report RM=0
    local tran
    tran=$(lsblk -dn -o TRAN "/dev/$dev" 2>/dev/null | tr -d '[:space:]')
    [[ "$tran" == "usb" ]] && return 0
    return 1
}

